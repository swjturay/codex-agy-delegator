{
  "name": "codex-agy-delegator",
  "version": "0.1.0",
  "description": "MCP Server for Codex to delegate tasks to Antigravity CLI",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/src/index.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "selfcheck": "echo 'Compiled and running'",
    "test:unit": "node --test dist/tests/*.test.js",
    "test": "npm run build && npm run test:unit && npm run selfcheck",
    "install:codex": "node scripts/install-codex-mcp.cjs",
    "install:skills": "node scripts/install-skills.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
