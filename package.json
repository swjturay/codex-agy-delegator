{
  "name": "codex-agy-delegator",
  "version": "0.1.0",
  "description": "MCP Server for Codex to delegate tasks to Antigravity CLI",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "ncc build src/index.ts -m -o dist",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "selfcheck": "echo 'Compiled and running'",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "test": "npm run build && npm run test:unit && npm run selfcheck",
    "setup": "node scripts/install.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.22.3",
    "typescript": "^5.3.0"
  }
}
